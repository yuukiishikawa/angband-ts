{
  "name": "angband-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Angband roguelike game rewritten in TypeScript",
  "workspaces": [
    "packages/@angband/*",
    "tools/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=20.0.0"
  }
}
